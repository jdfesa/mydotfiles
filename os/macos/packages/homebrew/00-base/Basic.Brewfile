# Referencia historica de una instalacion minima. No es el perfil principal.

tap "homebrew/bundle"
tap "homebrew/services"

brew "wget"
brew "git"
brew "tree"
cask "raindropio"
cask "google-chrome"
cask "spotify"
cask "hot"
brew "htop"
cask "google-drive"
cask "raycast"
cask "setapp"
brew "switchaudio-osx"
